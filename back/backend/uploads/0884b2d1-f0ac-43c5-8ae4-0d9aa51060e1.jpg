":"One Piece","selected_crop":"freeform","slide_image_link_url":"","slide_image_link_title":"","slide_image_link_new_tab":"0","slide_image_link_nofollow":"1","skip_slide_numbering":"0","dekDom":{"children":[{"children":[{"data":"Junto con Dragon Ball y Naruto, One Piece forma la santa trinidad del shonnen. Sin embargo, al contrario que las otras dos, las aventuras de Monkey D. Luffy, el hombre de goma, por convertirse en el rey de los piratas, continúan sin pausa más de dos décadas y más de mil capítulos después. Y lo asombroso es que lo ha hecho sin decaer.","type":"text"}],"name":"p","attribs":{},"type":"tag"},{"children":[{"data":"No te pierdas: ","type":"text"},{"children":[{"data":"en qué orden ver la serie y películas de 'One Piece'","type":"text"}],"name":"a","attribs":{"href":"https://www.fotogramas.es/series-tv-noticias/g42767589/one-piece-orden-cronologico-serie-temporadas-peliculas/","data-vars-ga-outbound-link":"https://www.fotogramas.es/series-tv-noticias/g42767589/one-piece-orden-cronologico-serie-temporadas-peliculas/","data-vars-ga-ux-element":"Hyperlink","data-vars-ga-call-to-action":"en qué orden ver la serie y películas de 'One Piece'","class":"body-link"},"type":"tag","_data":{}},{"data":".","type":"text"}],"name":"p","attribs":{},"type":"tag"},{"children":[{"data":"Además, hay que estar atento a la ","type":"text"},{"children":[{"data":"versión Live-Action de 'One Piece' que prepara Netflix","type":"text"}],"name":"a","attribs":{"href":"https://www.fotogramas.es/series-tv-noticias/a43485172/one-piece-netflix-fecha-estreno-reparto-trailer-imagenes/","data-vars-ga-outbound-link":"https://www.fotogramas.es/series-tv-noticias/a43485172/one-piece-netflix-fecha-estreno-reparto-trailer-imagenes/","data-vars-ga-ux-element":"Hyperlink","data-vars-ga-call-to-action":"versión Live-Action de 'One Piece' que prepara Netflix","class":"body-link"},"type":"tag","_data":{}},{"data":".","type":"text"}],"name":"p","attribs":{},"type":"tag"}],"type":"root"},"headli