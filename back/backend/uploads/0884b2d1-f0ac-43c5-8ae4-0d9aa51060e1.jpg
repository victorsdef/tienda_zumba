next/static/chunks/50783-176b4241838f057b.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/78396-4e81f7b2925c9822.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/88526-7e5a4b4c3f9530b8.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/80997-260f717b77489edc.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/49824-f7acd01892ab1ee3.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/78610-6f37ca99323f7f83.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/51462-b0f11d3a42ab5d93.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/7998-6e3d205f7f662c2e.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/17969-5ea258f1a34eabed.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/52481-fc129971a51f415d.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/41758-e401246415dc0fd3.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/32189-1c347f6ce2bbe705.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/59284-8627ba66d2506381.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/90177-ca88aba5492ec2fe.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/9664-c84a50acd758ffe1.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/94024-eed158d4d737183f.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/43948-1c18ac6df2333804.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/94217-9fdcaf554aed02e9.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/73938-f6d5390845bd86f9.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/65815-735c77a909e6b4fe.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/36950-9d8e2108b5b56b0c.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/30219-11533cfdfb9eec77.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/58944-96525edae29b40ad.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/79080-6759da8bf1ef7bd2.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/44570-c25a5962fc1e76c1.js" defer></script><script src="/_assets/fre/scopes/hdm/_next/static/chunks/pages/_templates/listicle-1af5d403f2de21f6.js" defer></script><link rel="preload" href="/_assets/design-tokens/fotogramas/static/fonts/Fjalla-One.07e1bf5.woff2" as="font" type="font/woff2" crossorigin="anonymous"/><link rel="stylesheet" href="/api/styles.css?id=bd20e54b-c038-45f1-913c-237883a8f266&amp;type=brand&amp;source=content%3Alisticle"/><meta name="app-version" content="1.8.689"/><script id="json-ld" type="application/ld+json">[{"@context":"http://schema.org","@type":"NewsArticle","thumbnailUrl":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=0.566xw:1.00xh;0.263xw,0&resize=100:*","datePublished":"2020-03-17T14:47:16.364545Z","headline":"Las 31 mejores series de anime japonés que debes ver","articleBody":"Las 31 mejores series de anime japonés de Netflix que debes verLas 25 mejores películas de anime japonés en Amazon Prime VideoLas 35 series más esperadas de 2023 para no perderseSi andas buscando las mejores series de anime japonés para empezar a ver hoy mismo, estás en el lugar adecuado: de 'My Hero Academia' a 'Ataque a los titanes', del catálogo de series de Netflix a las joyas disponibles entre las mejores series anime de Crunchyroll, desde estrenos recientes hasta clásicos con los que hay que saldar nuestras cuentas pendientes, nos proponemos reunir los mejores títulos para ver ya mismo y estar al día de los mejores animes actuales. ¡Apunta!Al igual que las mejores películas de anime japonés, las series animadas producidas en Japón causan furor en el mundo entero, también en España, gracias a su habilidad para convertir cualquier escenario e historia en aventuras apasionantes. Con una diferencia: las series las consumimos compulsivamente en cápsulas de 20 minutos. Lo típico que decides que una película de dos horas es muy larga para estas horas de la noche pero luego te cascas diez episodios seguidos de tu serie de anime favorita. ¡Todos lo hemos hecho! Y no nos arrepentimos: cuando una buena serie nos atrapa de esa manera, el disfrute está asegurado a pesar de los síntomas de adicción y posterior mono que nos entra cuando tenemos que parar porque alguien se tiene que levantar a la mañana siguiente para ir a trabajar. No nos cabe duda de que en esta lista vas a encontrar más de una serie (y de dos, y de tres...) que te provocará esta sensación de adicción absoluta. Díselo a los que ya están enganchados a 'Ataque a los titanes', una de las series de más éxito de los últimos años, y también de las más violentas, sangrientas y sorprendentes. El anime brilla sobre todo en estas historias de fantasía, ciencia ficción y distopía, cuando nos demuestran que la animación no tiene límites en su capacidad de retratar mundos inventados, tecnologías futuristas y mundos paralelos donde reina la más loca imaginación. Las legendarias 'Neon Genesis Evangelion' o 'Jojo's Bizarre Adventure' son grandes ejemplos de ello.De los mejores animes de terror a las series más románticas, esta lista intenta reunir una buena selección donde se unen estrenos recientes con clásicos. ¿El objetivo? Que puedas encontrar una serie para empezar esta misma noche y compruebes si realmente estás al día de lo mejor del anime presente y pasado. Somos conscientes de que nos faltarán algunos títulos célebres, pero lo que no se puede discutir es que, lo que está, es para no perdérselo. ¿Preparado? Aquí va una treintena de series de anime japonés, muchos de ellos disponibles ahora mismo en Netflix, Amazon Prime Video y otras plataformas de streaming. ¿Por cuál vas a empezar? Pluto Netflix está convirtiendo en seña de calidad sus series de animación, pero nunca se había atrevido con una anime nipón con tanto peso histórico para crear un anime que, desde su estreno, es de lo mejorcito de Netflix. El guionista de 'Pluto', Naoki Urasawa, creó el manga del mismo nombre en 2009 basándose en uno de los arcos del mítico 'Astro Boy', la obra más importante del conocido como \"Dios del manga\", Osamu Tezuke, gran padre y precursor de este arte. A lo largo de esta primera (y suponemos que única) temporada, vamos hacia un futuro donde humanos y robots viven casi a la par. Las IA se casan, adoptan niños e incluso tienen sueños y pesadillas (las más avanzadas, eso sí). Aunque no os queremos confundir, 'Pluto' pronto se convierte en un relato criminal y de misterio que podría hacer tambalear tal extraña equiparación entre humanos y máquinas. 'Pluto', sin embargo, va mucho más allá del misterio por encontrar al asesino y nos presenta una serie de preguntas tan sencillas como acertadas y emocionales sobre lo que es ser humano (o, en su defecto, estar realmente vivo). Kimetsu No Yaiba (Demon Slayer) Si hablamos de fenómenos actuales, 'Demon Slayer' está a la cabeza. Basada en el manga de Koyoharu Gotōge y convertida en una de las series de anime más aclamadas del momento, la historia sigue a Tanjirou Kamado, un chico inteligente y de buen corazón que mantiene a su familia vendiendo carbón, pero todo cambia cuando sus seres queridos son asesinados por un demonio. Con su hermana Nezuko, la única superviviente pero trágicamente convertida en demonio, el joven se convertirá en un asesino de demonios que no descansará hasta encontrar la cura para salvar a su hermana. La temporada 3 de 'Kimetsu no Yaiba' está en emisión ahora mismo (y disponible vía Crunchyroll). No te pierdas: en qué orden ver la serie y películas de 'Kimetsu no Yaiba (Demon Slayer)'. My Hero Academia Basada en el manga creado por Kōhei Horikoshi, 'My Hero Academia' cuenta la historia de Izuku Midoriya, un joven que vive en un mundo donde más de la mitad de la población ha desarrollado superpoderes, surgiendo así héroes y villanos, pero sus sueños quedarán aplastados cuando se dé cuenta de quél no ha desarrollado ningún poder. Es normal. Su mayor sueño era convertirse en un héroe como su ídolo 'All Might', y las cosas de la vida le ponen en el camino de este héroe, quien le escogerá como su heredero y le transferirá sus poderes. Ahora bien, ¿podrá Midoriya estar a la altura de las circunstancias? La temporada 7 de 'My Hero Academia' será la última, y ya contamos los minutos para verla. Mientras, no te pierdas: en qué orden ver la serie y películas de 'My Hero Academia'.  Ataque de los titanes (Shingeki No Kyojin) 'Ataque a los Titanes' es una serie basada en el manga del mismo nombre dirigida por Tetsuro Araki, protagonizada por un grupo de residentes de una ciudad rodeada de murallas, para proteger a la población de los ataques de gigantes caníbales, quienes de vez en cuando consiguen entrar en el lugar. La serie ha sido todo un fenómeno de público tras su adaptación televisiva y sigue adelante empujando los límites de su propio mundo de fantasía y terror. El final llegará con la temporada 3 de 'Ataque a los titanes (Shingeki No Kyojin)', así que ya nos preparamos para la despedida. No te pierdas: en qué orden ver la serie y películas de 'Ataque a los titanes'.  Jujutsu Kaisen El anime del momento, basado también en el manga número uno, esta animado por Mappa, el estudio detrás de 'Chainsaw Man' o 'Ataque a los titanes'. Todo un fenómeno que creció con su película precuela 'Jujutsu 0', para narrar la historia de unos jóvenes cazademonios contra criaturas infernales. Imaginación a raudales, personajes y poderes con carisma, toques de puro terror... Todo un shonnen que se convirtió en clásico con solo una temporada, y ahora vislumbra un prometedor futuro.La temporada 2 de 'Jujutsu Kaisen' llegará pronto.   One Piece Junto con Dragon Ball y Naruto, One Piece forma la santa trinidad del shonnen. Sin embargo, al contrario que las otras dos, las aventuras de Monkey D. Luffy, el hombre de goma, por convertirse en el rey de los piratas, continúan sin pausa más de dos décadas y más de mil capítulos después. Y lo asombroso es que lo ha hecho sin decaer.No te pierdas: en qué orden ver la serie y películas de 'One Piece'.Además, hay que estar atento a la versión Live-Action de 'One Piece' que prepara Netflix. Hunter X Hunter Clásico manga llevado a la pantalla en dos ocasiones, y que todavía sigue su curso de publicaciones. Sin embargo, a día de hoy la mejor manera de descubrir la historia de Gon, Killua y compañía son estos 148 episodios que se emitieron desde 2011 a 2014. En un mundo lleno de delincuencia, los grandes héroes se reúnen en una asociación de cazadores. Diremos que es eso lo que une a los protagonistas, pero sí algo define la obra de Yoshihiro Togashi es la gran diferencia tonal y temática entre arcos. Cada uno parece una aventura distinta, pero todavía más apasionante que la anterior. Además, aunque no llega al inexistente (por ahora) final del manga, la serie tiene un final cerrado y satisfactorio. Chainsaw Man Desde que acabó la primera temporada en diciembre de 2022 nos estamos comiendo las uñas para ver la temporada 2 de 'Chainsaw Man'. Aunque en Japón no ha sido del todo bien recibido debido a su polémico uso del CGI, lo cierto es que estamos ante uno de los animes más espectaculares, sorprendetes y atrevidos de los últimos años. Todo un fenómeno que, esperamos, tenga continuida. Al fin y al cabo, Pochita le dio a Denji su corazón por algo y el Demonio pistola no se va a matar sola. Cuanta, además, con Makima, una de las mejores femmes fatales que recordamos. Haikyuu Un hecho fortuito desencadena el amor de Shouyou Hinata por el voleibol. Su club no tenía ningún miembro, pero de algún modo perseveró y finalmente realizó su primer y último partido regular de la escuela secundaria, donde fue aniquilado por Tobio Kageyama, un jugador superestrella conocido como \"Rey de la Corte.\"El final de 'Haikyuu' se estrenará próximamente.  Neon Genesis Evangelion 'Evangelion' retrata una sociedad establecida en un hipotético 2015, después de que en 1999 ocurriera un enorme cataclismo provocado por seres conocidos como \"Ángeles\". Gran parte de la Tierra quedó devastada, y los pocos que quedaron ahora deben luchar contra los ataques de los Ángeles. Una organización llamada NERV acaba de crear Evas, máquinas gigantes biomecánicas que sirven para combatir contra estas amenazas. Pero solo algunos niños pueden pilotarlos. Entre ellos Shinji Ikari, el hijo del jefe de NERV. Apunta: Neon Genenisis Evangelion: dónde y en qué orden ver la serie y películas.  Jojo's Bizarre Adventure Basada en el manga de Hirohiko Araki, este anime tan aclamado (y convertido en una película de acción real dirigida pro Takashi Miike) nos traslada hasta la Gran Bretaña de finales del siglo XIX, donde Jonathan Joestar conoce a su nuevo hermano adoptivo, Dio Brando, que ambiciona quitarle el puesto de heredero de la familia. Y a partir de ahí las cosas empiezan a ponerse \"bizarras\": Dío usa una máscara de piedra de origen mesoamericano que lo convierte en un vampiro, así que Jonathan reunirá un equipo para detenerlo antes de que destruya el mundo. Violet Evergarden  Mezcla perfecta de acción, comedia y romance, 'Violet Evergarden' es la opción perfecta para aquellos que busquen alejarse de animes más oscuros y violentos. Basada en la obra de Kana Akatsuki, la historia sigue a una joven, cuyo nombre ocupa el título de la serie, que abandona el campo de batalla para comenzar una nueva vida en un servicio postal. Profundamente conmovida por el trabajo de 'Auto Memories Dolls', que trasladan los pensamientos de la gente y los convierten en palabras, comienza su viaje como una de ellas y se encuentra cara a cara con la emociones de varias personas y diferentes formas de amor. No te pierdas: en qué orden ver la serie y películas de 'Violet Evergarden'.  Tokyo Ghoul En Tokyo ocurren asesinatos misteriosos cometidos por Ghouls, seres desconocidos que comen carne humana. Un día, el estudiante Kaneki Ken, de apenas 18 años, conoce a una chica en un restaurante y la invita a salir, pero luego se da cuenta que ella es un Ghoul y sufre un ataque. Sobrevive, pero al recibir atención médica y trasplantarle el riñón de la joven, le convierten sin saberlo en un híbrido entre hombre y ghoul, lo que lo hace increíblemente especial a la vez que lo pone en peligro. Uno de los 10 mangas más vendidos de los últimos años merecía un anime a la altura. Castlevania  Trevor Belmont es un cazavampiros que intenta defender la nación de Wallachia de la amenaza de Drácula y su ejército de muertos y monstruos. Las mejores series de vampiros tuvieron una nueva incorporación con esta serie de Netflix, cargada de acción, sangre y suspense. ¿Habrá temporada 5 de 'Castlevania'? Paranoia Agent Si la firma Satoshi Kon, se convierte en automáticamente imprescindible. El director de algunas de las mejores películas de animación de la historia como 'Perfect Blue' o 'Paprika' también se pasó a las series con esta absoluta joya compuesta por trece episodios. La historia sigue a una diseñadora gráfica de Tokyo, autora de una mascota muy popular, que, a pesar de ser la envidia de sus compañeros, está en un estado depresivo porque se siente aislada y bajo presión por volver a triunfar. Un día, de regreso a casa, es atacada violentamente por Shounen Bat, un chico en patines y con un bate torcido que se convierte en una auténtica leyenda urbana. Además, ahora acaba de llegar a Prime Video. Berserk Kentaro Miura falleció en 2022 dejando su gran obra sin acabar. Pero lo importante es el viaje y la adaptación de 1997 del arco de la Edad Dorada de Berserk sigue siendo uno de los momentos más brillantes tanto del manga como del anime. Con 'Berserk' no estamos ante un mero producto de entretenimiento de masas si no ante una creación personal, única y propia. Hay traición, hay amor, hay demonios, pero sobre todo hay soledad, ira, depresión y venganza. No es una historia que sirva precisamente para levantar el anime pero sí es, innegablemente una obra de arte. PD: No confundir con animaciones posteriores a la del 97, todas muy por debajo del nivel de estos 25 capítulos. Mushishi Basada en el manga de Yuki Urushibara, 'Mushishi' es una joya infravalorada que seguro que aún está por descubrir para muchos fans del anime y seriéfilos en general. El protagonista, que es experto en las criaturas conocidas como Mushis (de ahí Mushishi), recorre el mundo con el objetivo de ayudar a aquellas personas cuyas vidas se han visto alteradas al entrar en contacto con estos Mushis, que habitualmente actúan como parásitos. Monster Netflix ya tiene al completo este auténtico clasicazo del anime. Probablemente el mejor anime criminal de la historia, compuesto por 74 capítulos, la obra de Naoki Urosawa es un relato adulto y muy negro. Todo parte de un prodigioso y bondadoso doctor que se enfrenta a su jefe para salvar a un niño... Un niño que quizás no debió ser salvado. La importancia de la vida, la línea entre el bien y el mal y la altura moral son los centros de este relato sobre asesinos en serie y fascismo.  Devilman Crybaby Basada en el manga de Gō Nagai y dirigida por el gran Masaaki Yuasa (director de películas de animación gloriosas como 'Night is short, walk on girl'), 'Devilman Crybaby' sigue a un joven, Akira Fudō, que es informado por su mejor amigo, Ryō Asuka, de que una antigua raza de demonios ha regresado para conquistar el mundo de los humanos. Creyendo que la única forma de derrotar a los demonios es apoderarse de sus poderes, Ryō le sugiere a Akira que se una con un demonio. Al tener éxito al hacerlo, Akira se transforma en Devilman. Bleach  Creado y adaptado por el mangaka Kubo Tite, 'Bleach' se convirtió poco a poco en uno de los títulos más icónicos del anime reciente. La historia siguea Ichigo Kurosaki, un chico de 15 años que puede ver espíritus. Intentando proteger el espíritu de una niña pequeña, tiene un encuentro con un espíritu malvado y una shinigami. Después Ichigo Kurosaki encuentra a la chica en su habitación, que se presenta como Rukia Kuchiki, y explica el objetivo de los shinigami: para salvar a su familia, se tendrá que convertir en uno. Acaba de estrenarse al completo en Disney + junto con 'La guerra sangrienta de los mil años', el arco que le pondrá fin a la historia. Death Note Death Note cuenta la historia sobre un joven llamado Yagami Light. Un aburrido día de clase ve caer un cuaderno negro en el patio de su escuela, titulado Death Note. Según las instrucciones escritas en el mismo cuaderno, aquella persona cuyo nombre sea escrito en dicho cuaderno, morirá. Naruto La historia transcurre en un mundo dominado por aldeas ninja. En las cuales el papel del ninja se traduce como el poder de cada país. Cada uno de estos cuenta con su aldea oculta que es donde estudian, entrenan, gradúan y forman cada ninja. Los ninjas utilizan todo tipo de artes marciales desde la lucha cuerpo a cuerpo a ilusiones o técnicas secretas como por ejemplo la manipulación de elementos. Banana Fish 1973, Vietnam. Un soldado estadounidense enloquece y abate a sus compañeros. Desde entonces, las únicas palabras que pronuncia son \"Banana Fish\". En la actualidad, en la ciudad de Nueva York, la policía investiga una serie de desconcertantes suicidios.  Assasination Classroom Una criatura ha destruido el 70% de la Luna, dejándola en una fase creciente perpetua, además, este ser anuncia a los seres humanos que, en un año, la Tierra correrá la misma suerte a menos que los estudiantes de la clase 3-E del instituto Kunugigaoka, donde da lecciones sobre asesinato, consigan matarlo, una hazaña que tendría, además, una recompensa del gobierno japonés de diez mil millones de yenes. After the rain Akira Tachibana es una adolescente de 17 años, con un gran talento para el atletismo, que ve frustrada su carrera cuando se lesiona gravemente un talón de Aquiles. Comienza a trabajar en un restaurante, regentado por Masami Kondo, un hombre de 45 años. La humildad, simpatía y ternura de Kondo, cautivan a Akira, haciendo que se enamore perdidamente de él, sin importarle la diferencia de edad.  Blue Exorcist Este mundo se compone de dos dimensiones unidas en una sola, como un espejo. La primera es Assiah, el mundo donde viven los humanos, la otra Gehenna lugar donde habitan los demonios. Por lo general viajar entre las dos dimensiones o cualquier tipo de contacto entra estas es algo imposible de realizar. En Ao No Exorcist encontramos a Satanás, rey de los demonios en Gehenna y aunque quisiera hacer todo lo que los demás hacen no puede ya que no hay nada tan poderoso como él que pueda contenerlo sin causar destrucción, entonces engendra un hijo con una humana, un joven llamado Rin, para cumplir su propósito, pero lo que no sabe es que este al enterarse que es hijo de Satanás decide unirse a una escuela especial para luchar contra los demonios convirtiéndose en un... exorcista. Pyscho-Pass En el futuro, es posible de medir de manera cuantitativa las emociones, deseos e inclinaciones de una persona. De esta manera, también puede ser medida la tendencia criminal la cual es usada para juzgar a los criminales. Esta es la historia de un equipo de policías dedicados a mantener el orden público. Algunos de ellos trabajan en la Fuerza responsable del arresto de los criminales mientras otros trabajan en Supervisión los cuales vigilan a sus colegas.  Pokémon En Pueblo Paleta, todos los niños y niñas están fascinados por el mundo de los Pokémon, unas criaturas de diferentes formas y colores que cuentan con unos poderes muy especiales. Ash Ketchum es uno de ellos, un niño de 10 años que sueña con llegar a ser el mejor entrenador Pokémon del mundo.  Cuando las cigarras lloran Higurashi no Naku Koro Ni narra la historia acerca de la llamada Maldición de Oyashiro-sama, consistente en el asesinato de una persona y la desaparición de otra, que se cumple todos los años en la tranquila villa de Hinamizawa desde unos incidentes de 5 años atrás durante la noche festiva del Watanagashi. Keiichi Maebara y su grupo de amigos, que hasta esa noche viven tranquilamente en la villa, se ven envueltos en el caso de la maldición en las varias sagas. Cada una de estas sagas revela varios detalles acerca de la \"maldición\" y tiene un final distinto que acaba, normalmente, con el asesinato de algunos miembros del grupo. Doraemon Nobita y Doraemon se metan en miles de líos de los que deberán salir con una combinación de imaginación, suerte y valentía. Bakugan Battle Planet Dan Kouzo y sus amigos son los primeros niños de la Tierra que crean un vínculo con unas misteriosas criaturas conocidas como Bakugan.","wordCount":null,"articleSection":"Series TV","image":[{"@type":"ImageObject","height":1200,"thumbnail":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=0.566xw:1.00xh;0.263xw,0&resize=100:*","url":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=0.566xw:1.00xh;0.263xw,0&resize=1200:*","width":1200},{"@type":"ImageObject","height":900,"thumbnail":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=0.566xw:1.00xh;0.263xw,0&resize=100:*","url":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=0.75xw:1xh;center,top&resize=1200:*","width":1200},{"@type":"ImageObject","height":675,"thumbnail":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=0.566xw:1.00xh;0.263xw,0&resize=100:*","url":"https://hips.hearstapps.com/hmg-prod/images/pluto-5-653d534fe4511.jpg?crop=1xw:1xh;center,top&resize=1200:*","width":1200}],"mainEntityOfPage":{"@id":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/","@type":"WebPage"},"publisher":{"@type":"NewsMediaOrganization","name":"Fotogramas","sameAs":["https://x.com/fotogramas_es","https://www.youtube.com/user/fotogramastv","https://www.facebook.com/fotogramas.es","https://www.instagram.com/fotogramas_es/","https://es.wikipedia.org/wiki/Fotogramas_(revista)"],"logo":{"@type":"ImageObject","url":"https://www.fotogramas.es/_assets/design-tokens/fotogramas/static/images/logos/logo-jsonld.a6fb4c9.png","width":312,"height":60},"address":{"@type":"PostalAddress","postalCode":"28036","addressRegion":"Madrid","streetAddress":"C/ Agustín de Foxá, 4","addressCountry":"Spain","addressLocality":"Madrid"},"publishingPrinciples":"https://www.fotogramas.es/informacion/a22495266/contacto/","parentOrganization":{"@type":"NewsMediaOrganization","name":"Hearst Corporation","url":"https://www.hearstmagazinesinternational.com/","sameAs":["https://es.wikipedia.org/wiki/Hearst_Communications","https://www.linkedin.com/company/hearst-espa%C3%B1a/"],"address":{"postalCode":"10019","addressRegion":"NY","streetAddress":"300 W 57th Street","addressCountry":"US","addressLocality":"New York"}}},"keywords":["content-type: Default","locale: ES","displayType: listicle","shortTitle: Las 31 mejores series de anime japonés para ver ya","contentId: 0525c9e0-f595-4187-baea-e6b465ba651a","collection: Cine y series de anime","collection: My Hero Academia","sponsored: false","isSyndicated: false"],"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/","isBasedOn":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/","dateModified":"2023-10-28T18:35:00Z","description":"Desde 'Kimetsu No Yaiba' hasta 'Neon Genesis Evangelion', pasando por clásicos como 'Death Note' y 'Paranoia Agent' o estrenos recientes como 'Pluto'.","author":[{"name":"Juan Arcones","url":"https://www.fotogramas.es/author/630004/juan-arcones/","@type":"Person"},{"name":"Mireia Mullor","url":"https://www.fotogramas.es/author/208537/mireia-mullor/","@type":"Person","description":"\u003cp>Mireia es experta en cine y series en la revista FOTOGRAMAS, donde escribe sobre todo tipo de estrenos de películas y series de Netflix, HBO Max y más. Su ídolo es Agnès Varda y le apasiona el cine de autor, pero también está al día de todas las noticias de Marvel, Disney, Star Wars y otras franquicias, y tiene debilidad por el anime japonés; un perfil polifacético que también ha demostrado en cabeceras como ESQUIRE y ELLE.\u003c/p>\n\u003cp>En sus siete años en FOTOGRAMAS ha conseguido hacerse un hueco como redactora y especialista SEO en la web, y también colabora y forma parte del cuadro crítico de la edición impresa. Ha tenido la oportunidad de entrevistar a estrellas de la talla de Ryan Gosling, Jake Gyllenhaal, Zendaya y Kristen Stewart (aunque la que más ilusión le hizo sigue siendo Jane Campion), cubrir grandes eventos como los Oscars y asistir a festivales como los de San Sebastián, Londres, Sevilla y Venecia (en el que ha ejercido de jurado FIPRESCI). Además, ha participado en campañas de contenidos patrocinados con el equipo de Hearst Magazines España, y tiene cierta experiencia en departamentos de comunicación y como programadora a través del Kingston International Film Festival de Londres.\u003c/p>\n\u003cp>Mireia es graduada en Periodismo por la Universidad Autónoma de Barcelona (UAB) y empezó su carrera como periodista cinematográfica en medios online como la revista Insertos y Cine Divergente, entre otros. En 2023 se publica su primer libro, 'Biblioteca Studio Ghibli: Nicky, la aprendiz de bruja' (Editorial Héroes de Papel), un ensayo en profundidad sobre la película de Hayao Miyazaki de 1989. &nbsp;&nbsp;\u003c/p>","image":"https://hips.hearstapps.com/rover/profile_photos/193c72e6-47b7-43ed-b217-ef35ce6f616c_1596101430.jpg","email":"mireiamullor@gmail.com"}]},{"@context":"http://schema.org","@type":"ItemList","numberOfItems":31,"itemListElement":[{"@type":"ListItem","position":1,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-1","name":"Pluto","description":"Netflix está convirtiendo en seña de calidad sus series de animación, pero nunca se había atrevido con una anime nipón con tanto peso histórico para crear un anime que, desde su estreno, es de lo mejorcito de Netflix. El guionista de 'Pluto', Naoki Urasawa, creó el manga del mismo nombre en 2009 basándose en uno de los arcos del mítico 'Astro Boy', la obra más importante del conocido como \"Dios del manga\", Osamu Tezuke, gran padre y precursor de este arte. A lo largo de esta primera (y suponemos que única) temporada, vamos hacia un futuro donde humanos y robots viven casi a la par. Las IA se casan, adoptan niños e incluso tienen sueños y pesadillas (las más avanzadas, eso sí). Aunque no os queremos confundir, 'Pluto' pronto se convierte en un relato criminal y de misterio que podría hacer tambalear tal extraña equiparación entre humanos y máquinas. 'Pluto', sin embargo, va mucho más allá del misterio por encontrar al asesino y nos presenta una serie de preguntas tan sencillas como acertadas y emocionales sobre lo que es ser humano (o, en su defecto, estar realmente vivo).","image":"https://hips.hearstapps.com/hmg-prod/images/pluto-653d43064d2b5.jpg"},{"@type":"ListItem","position":2,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-2","name":"Kimetsu No Yaiba (Demon Slayer)","description":"Si hablamos de fenómenos actuales, 'Demon Slayer' está a la cabeza. Basada en el manga de Koyoharu Gotōge y convertida en una de las series de anime más aclamadas del momento, la historia sigue a Tanjirou Kamado, un chico inteligente y de buen corazón que mantiene a su familia vendiendo carbón, pero todo cambia cuando sus seres queridos son asesinados por un demonio. Con su hermana Nezuko, la única superviviente pero trágicamente convertida en demonio, el joven se convertirá en un asesino de demonios que no descansará hasta encontrar la cura para salvar a su hermana. La temporada 3 de 'Kimetsu no Yaiba' está en emisión ahora mismo (y disponible vía Crunchyroll). No te pierdas: en qué orden ver la serie y películas de 'Kimetsu no Yaiba (Demon Slayer)'.","image":"https://hips.hearstapps.com/hmg-prod/images/demon-slayer-1643910214.jpg"},{"@type":"ListItem","position":3,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-3","name":"My Hero Academia","description":"Basada en el manga creado por Kōhei Horikoshi, 'My Hero Academia' cuenta la historia de Izuku Midoriya, un joven que vive en un mundo donde más de la mitad de la población ha desarrollado superpoderes, surgiendo así héroes y villanos, pero sus sueños quedarán aplastados cuando se dé cuenta de quél no ha desarrollado ningún poder. Es normal. Su mayor sueño era convertirse en un héroe como su ídolo 'All Might', y las cosas de la vida le ponen en el camino de este héroe, quien le escogerá como su heredero y le transferirá sus poderes. Ahora bien, ¿podrá Midoriya estar a la altura de las circunstancias? La temporada 7 de 'My Hero Academia' será la última, y ya contamos los minutos para verla. Mientras, no te pierdas: en qué orden ver la serie y películas de 'My Hero Academia'. ","image":"https://hips.hearstapps.com/hmg-prod/images/my-hero-academia-1584454230.jpg"},{"@type":"ListItem","position":4,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-4","name":"Ataque de los titanes (Shingeki No Kyojin)","description":"'Ataque a los Titanes' es una serie basada en el manga del mismo nombre dirigida por Tetsuro Araki, protagonizada por un grupo de residentes de una ciudad rodeada de murallas, para proteger a la población de los ataques de gigantes caníbales, quienes de vez en cuando consiguen entrar en el lugar. La serie ha sido todo un fenómeno de público tras su adaptación televisiva y sigue adelante empujando los límites de su propio mundo de fantasía y terror. El final llegará con la temporada 3 de 'Ataque a los titanes (Shingeki No Kyojin)', así que ya nos preparamos para la despedida. No te pierdas: en qué orden ver la serie y películas de 'Ataque a los titanes'. ","image":"https://hips.hearstapps.com/hmg-prod/images/ataque-de-los-titanes-1584454229.jpeg"},{"@type":"ListItem","position":5,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-5","name":"Jujutsu Kaisen","description":"El anime del momento, basado también en el manga número uno, esta animado por Mappa, el estudio detrás de 'Chainsaw Man' o 'Ataque a los titanes'. Todo un fenómeno que creció con su película precuela 'Jujutsu 0', para narrar la historia de unos jóvenes cazademonios contra criaturas infernales. Imaginación a raudales, personajes y poderes con carisma, toques de puro terror... Todo un shonnen que se convirtió en clásico con solo una temporada, y ahora vislumbra un prometedor futuro.La temporada 2 de 'Jujutsu Kaisen' llegará pronto.  ","image":"https://hips.hearstapps.com/hmg-prod/images/jujutsu-kaisen-1667648857.jpg"},{"@type":"ListItem","position":6,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-6","name":"One Piece","description":"Junto con Dragon Ball y Naruto, One Piece forma la santa trinidad del shonnen. Sin embargo, al contrario que las otras dos, las aventuras de Monkey D. Luffy, el hombre de goma, por convertirse en el rey de los piratas, continúan sin pausa más de dos décadas y más de mil capítulos después. Y lo asombroso es que lo ha hecho sin decaer.No te pierdas: en qué orden ver la serie y películas de 'One Piece'.Además, hay que estar atento a la versión Live-Action de 'One Piece' que prepara Netflix.","image":"https://hips.hearstapps.com/hmg-prod/images/one-piece-top-mangas-mas-vendidos-1543851031.jpg"},{"@type":"ListItem","position":7,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-7","name":"Hunter X Hunter","description":"Clásico manga llevado a la pantalla en dos ocasiones, y que todavía sigue su curso de publicaciones. Sin embargo, a día de hoy la mejor manera de descubrir la historia de Gon, Killua y compañía son estos 148 episodios que se emitieron desde 2011 a 2014. En un mundo lleno de delincuencia, los grandes héroes se reúnen en una asociación de cazadores. Diremos que es eso lo que une a los protagonistas, pero sí algo define la obra de Yoshihiro Togashi es la gran diferencia tonal y temática entre arcos. Cada uno parece una aventura distinta, pero todavía más apasionante que la anterior. Además, aunque no llega al inexistente (por ahora) final del manga, la serie tiene un final cerrado y satisfactorio.","image":"https://hips.hearstapps.com/hmg-prod/images/hunter-x-hunter-1667648857.jpg"},{"@type":"ListItem","position":8,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-8","name":"Chainsaw Man","description":"Desde que acabó la primera temporada en diciembre de 2022 nos estamos comiendo las uñas para ver la temporada 2 de 'Chainsaw Man'. Aunque en Japón no ha sido del todo bien recibido debido a su polémico uso del CGI, lo cierto es que estamos ante uno de los animes más espectaculares, sorprendetes y atrevidos de los últimos años. Todo un fenómeno que, esperamos, tenga continuida. Al fin y al cabo, Pochita le dio a Denji su corazón por algo y el Demonio pistola no se va a matar sola. Cuanta, además, con Makima, una de las mejores femmes fatales que recordamos.","image":"https://hips.hearstapps.com/hmg-prod/images/chainsaw-man-5-1670073306.jpg"},{"@type":"ListItem","position":9,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-9","name":"Haikyuu","description":"Un hecho fortuito desencadena el amor de Shouyou Hinata por el voleibol. Su club no tenía ningún miembro, pero de algún modo perseveró y finalmente realizó su primer y último partido regular de la escuela secundaria, donde fue aniquilado por Tobio Kageyama, un jugador superestrella conocido como \"Rey de la Corte.\"El final de 'Haikyuu' se estrenará próximamente. ","image":"https://hips.hearstapps.com/hmg-prod/images/haikyuu-1584454227.jpg"},{"@type":"ListItem","position":10,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-10","name":"Neon Genesis Evangelion","description":"'Evangelion' retrata una sociedad establecida en un hipotético 2015, después de que en 1999 ocurriera un enorme cataclismo provocado por seres conocidos como \"Ángeles\". Gran parte de la Tierra quedó devastada, y los pocos que quedaron ahora deben luchar contra los ataques de los Ángeles. Una organización llamada NERV acaba de crear Evas, máquinas gigantes biomecánicas que sirven para combatir contra estas amenazas. Pero solo algunos niños pueden pilotarlos. Entre ellos Shinji Ikari, el hijo del jefe de NERV. Apunta: Neon Genenisis Evangelion: dónde y en qué orden ver la serie y películas. ","image":"https://hips.hearstapps.com/hmg-prod/images/neon-genesis-evangelion-1657885237.jpg"},{"@type":"ListItem","position":11,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-11","name":"Jojo's Bizarre Adventure","description":"Basada en el manga de Hirohiko Araki, este anime tan aclamado (y convertido en una película de acción real dirigida pro Takashi Miike) nos traslada hasta la Gran Bretaña de finales del siglo XIX, donde Jonathan Joestar conoce a su nuevo hermano adoptivo, Dio Brando, que ambiciona quitarle el puesto de heredero de la familia. Y a partir de ahí las cosas empiezan a ponerse \"bizarras\": Dío usa una máscara de piedra de origen mesoamericano que lo convierte en un vampiro, así que Jonathan reunirá un equipo para detenerlo antes de que destruya el mundo.","image":"https://hips.hearstapps.com/hmg-prod/images/jojos-bizarre-adventure-1626781070.jpg"},{"@type":"ListItem","position":12,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-12","name":"Violet Evergarden ","description":"Mezcla perfecta de acción, comedia y romance, 'Violet Evergarden' es la opción perfecta para aquellos que busquen alejarse de animes más oscuros y violentos. Basada en la obra de Kana Akatsuki, la historia sigue a una joven, cuyo nombre ocupa el título de la serie, que abandona el campo de batalla para comenzar una nueva vida en un servicio postal. Profundamente conmovida por el trabajo de 'Auto Memories Dolls', que trasladan los pensamientos de la gente y los convierten en palabras, comienza su viaje como una de ellas y se encuentra cara a cara con la emociones de varias personas y diferentes formas de amor. No te pierdas: en qué orden ver la serie y películas de 'Violet Evergarden'. ","image":"https://hips.hearstapps.com/hmg-prod/images/a-quien-conocio-violet-evergarden-al-final-1646853125.jpg"},{"@type":"ListItem","position":13,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-13","name":"Tokyo Ghoul","description":"En Tokyo ocurren asesinatos misteriosos cometidos por Ghouls, seres desconocidos que comen carne humana. Un día, el estudiante Kaneki Ken, de apenas 18 años, conoce a una chica en un restaurante y la invita a salir, pero luego se da cuenta que ella es un Ghoul y sufre un ataque. Sobrevive, pero al recibir atención médica y trasplantarle el riñón de la joven, le convierten sin saberlo en un híbrido entre hombre y ghoul, lo que lo hace increíblemente especial a la vez que lo pone en peligro. Uno de los 10 mangas más vendidos de los últimos años merecía un anime a la altura.","image":"https://hips.hearstapps.com/hmg-prod/images/tokyo-ghoul-1584454233.jpg"},{"@type":"ListItem","position":14,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-14","name":"Castlevania ","description":"Trevor Belmont es un cazavampiros que intenta defender la nación de Wallachia de la amenaza de Drácula y su ejército de muertos y monstruos. Las mejores series de vampiros tuvieron una nueva incorporación con esta serie de Netflix, cargada de acción, sangre y suspense. ¿Habrá temporada 5 de 'Castlevania'?","image":"https://hips.hearstapps.com/es.h-cdn.co/fotoes/images/series-television/castlevania-temporada-2-fecha-estreno-netflix/137802091-1-esl-ES/Castlevania-la-temporada-2-ya-tiene-fecha-de-regreso-a-Netflix.jpg"},{"@type":"ListItem","position":15,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-15","name":"Paranoia Agent","description":"Si la firma Satoshi Kon, se convierte en automáticamente imprescindible. El director de algunas de las mejores películas de animación de la historia como 'Perfect Blue' o 'Paprika' también se pasó a las series con esta absoluta joya compuesta por trece episodios. La historia sigue a una diseñadora gráfica de Tokyo, autora de una mascota muy popular, que, a pesar de ser la envidia de sus compañeros, está en un estado depresivo porque se siente aislada y bajo presión por volver a triunfar. Un día, de regreso a casa, es atacada violentamente por Shounen Bat, un chico en patines y con un bate torcido que se convierte en una auténtica leyenda urbana. Además, ahora acaba de llegar a Prime Video.","image":"https://hips.hearstapps.com/hmg-prod/images/paranoia-agent-1657884893.jpg"},{"@type":"ListItem","position":16,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-16","name":"Berserk","description":"Kentaro Miura falleció en 2022 dejando su gran obra sin acabar. Pero lo importante es el viaje y la adaptación de 1997 del arco de la Edad Dorada de Berserk sigue siendo uno de los momentos más brillantes tanto del manga como del anime. Con 'Berserk' no estamos ante un mero producto de entretenimiento de masas si no ante una creación personal, única y propia. Hay traición, hay amor, hay demonios, pero sobre todo hay soledad, ira, depresión y venganza. No es una historia que sirva precisamente para levantar el anime pero sí es, innegablemente una obra de arte. PD: No confundir con animaciones posteriores a la del 97, todas muy por debajo del nivel de estos 25 capítulos.","image":"https://hips.hearstapps.com/hmg-prod/images/berserk-esta-excelente-noticia-hara-las-delicias-de-los-fans-1671611053.jpg"},{"@type":"ListItem","position":17,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-17","name":"Mushishi","description":"Basada en el manga de Yuki Urushibara, 'Mushishi' es una joya infravalorada que seguro que aún está por descubrir para muchos fans del anime y seriéfilos en general. El protagonista, que es experto en las criaturas conocidas como Mushis (de ahí Mushishi), recorre el mundo con el objetivo de ayudar a aquellas personas cuyas vidas se han visto alteradas al entrar en contacto con estos Mushis, que habitualmente actúan como parásitos.","image":"https://hips.hearstapps.com/hmg-prod/images/mushishi-1657885087.jpg"},{"@type":"ListItem","position":18,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-18","name":"Monster","description":"Netflix ya tiene al completo este auténtico clasicazo del anime. Probablemente el mejor anime criminal de la historia, compuesto por 74 capítulos, la obra de Naoki Urosawa es un relato adulto y muy negro. Todo parte de un prodigioso y bondadoso doctor que se enfrenta a su jefe para salvar a un niño... Un niño que quizás no debió ser salvado. La importancia de la vida, la línea entre el bien y el mal y la altura moral son los centros de este relato sobre asesinos en serie y fascismo. ","image":"https://hips.hearstapps.com/hmg-prod/images/monster-anime-1676743612.jpg"},{"@type":"ListItem","position":19,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-19","name":"Devilman Crybaby","description":"Basada en el manga de Gō Nagai y dirigida por el gran Masaaki Yuasa (director de películas de animación gloriosas como 'Night is short, walk on girl'), 'Devilman Crybaby' sigue a un joven, Akira Fudō, que es informado por su mejor amigo, Ryō Asuka, de que una antigua raza de demonios ha regresado para conquistar el mundo de los humanos. Creyendo que la única forma de derrotar a los demonios es apoderarse de sus poderes, Ryō le sugiere a Akira que se una con un demonio. Al tener éxito al hacerlo, Akira se transforma en Devilman.","image":"https://hips.hearstapps.com/hmg-prod/images/mejores-series-anime-netflix-devilman-crybaby-1555346263.jpg"},{"@type":"ListItem","position":20,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-20","name":"Bleach ","description":"Creado y adaptado por el mangaka Kubo Tite, 'Bleach' se convirtió poco a poco en uno de los títulos más icónicos del anime reciente. La historia siguea Ichigo Kurosaki, un chico de 15 años que puede ver espíritus. Intentando proteger el espíritu de una niña pequeña, tiene un encuentro con un espíritu malvado y una shinigami. Después Ichigo Kurosaki encuentra a la chica en su habitación, que se presenta como Rukia Kuchiki, y explica el objetivo de los shinigami: para salvar a su familia, se tendrá que convertir en uno. Acaba de estrenarse al completo en Disney + junto con 'La guerra sangrienta de los mil años', el arco que le pondrá fin a la historia.","image":"https://hips.hearstapps.com/hmg-prod/images/top-10-animes-sobrevalorados-bleach-1553526307.jpg"},{"@type":"ListItem","position":21,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-21","name":"Death Note","description":"Death Note cuenta la historia sobre un joven llamado Yagami Light. Un aburrido día de clase ve caer un cuaderno negro en el patio de su escuela, titulado Death Note. Según las instrucciones escritas en el mismo cuaderno, aquella persona cuyo nombre sea escrito en dicho cuaderno, morirá.","image":"https://hips.hearstapps.com/es.h-cdn.co/fotoes/images/series-television/mejores-series-anime-netflix-espana/death-note-anime/113504860-1-esl-ES/death-note-anime.jpg"},{"@type":"ListItem","position":22,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-22","name":"Naruto","description":"La historia transcurre en un mundo dominado por aldeas ninja. En las cuales el papel del ninja se traduce como el poder de cada país. Cada uno de estos cuenta con su aldea oculta que es donde estudian, entrenan, gradúan y forman cada ninja. Los ninjas utilizan todo tipo de artes marciales desde la lucha cuerpo a cuerpo a ilusiones o técnicas secretas como por ejemplo la manipulación de elementos.","image":"https://hips.hearstapps.com/hmg-prod/images/naruto-1584454238.png"},{"@type":"ListItem","position":23,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-23","name":"Banana Fish","description":"1973, Vietnam. Un soldado estadounidense enloquece y abate a sus compañeros. Desde entonces, las únicas palabras que pronuncia son \"Banana Fish\". En la actualidad, en la ciudad de Nueva York, la policía investiga una serie de desconcertantes suicidios. ","image":"https://hips.hearstapps.com/hmg-prod/images/banana-fish-1584454228.jpg"},{"@type":"ListItem","position":24,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-24","name":"Assasination Classroom","description":"Una criatura ha destruido el 70% de la Luna, dejándola en una fase creciente perpetua, además, este ser anuncia a los seres humanos que, en un año, la Tierra correrá la misma suerte a menos que los estudiantes de la clase 3-E del instituto Kunugigaoka, donde da lecciones sobre asesinato, consigan matarlo, una hazaña que tendría, además, una recompensa del gobierno japonés de diez mil millones de yenes.","image":"https://hips.hearstapps.com/hmg-prod/images/assasination-classroom-1584454227.jpg"},{"@type":"ListItem","position":25,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-25","name":"After the rain","description":"Akira Tachibana es una adolescente de 17 años, con un gran talento para el atletismo, que ve frustrada su carrera cuando se lesiona gravemente un talón de Aquiles. Comienza a trabajar en un restaurante, regentado por Masami Kondo, un hombre de 45 años. La humildad, simpatía y ternura de Kondo, cautivan a Akira, haciendo que se enamore perdidamente de él, sin importarle la diferencia de edad. ","image":"https://hips.hearstapps.com/hmg-prod/images/after-the-rain-1584454227.jpg"},{"@type":"ListItem","position":26,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-26","name":"Blue Exorcist","description":"Este mundo se compone de dos dimensiones unidas en una sola, como un espejo. La primera es Assiah, el mundo donde viven los humanos, la otra Gehenna lugar donde habitan los demonios. Por lo general viajar entre las dos dimensiones o cualquier tipo de contacto entra estas es algo imposible de realizar. En Ao No Exorcist encontramos a Satanás, rey de los demonios en Gehenna y aunque quisiera hacer todo lo que los demás hacen no puede ya que no hay nada tan poderoso como él que pueda contenerlo sin causar destrucción, entonces engendra un hijo con una humana, un joven llamado Rin, para cumplir su propósito, pero lo que no sabe es que este al enterarse que es hijo de Satanás decide unirse a una escuela especial para luchar contra los demonios convirtiéndose en un... exorcista.","image":"https://hips.hearstapps.com/hmg-prod/images/blue-exorcist-1584454230.png"},{"@type":"ListItem","position":27,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-27","name":"Pyscho-Pass","description":"En el futuro, es posible de medir de manera cuantitativa las emociones, deseos e inclinaciones de una persona. De esta manera, también puede ser medida la tendencia criminal la cual es usada para juzgar a los criminales. Esta es la historia de un equipo de policías dedicados a mantener el orden público. Algunos de ellos trabajan en la Fuerza responsable del arresto de los criminales mientras otros trabajan en Supervisión los cuales vigilan a sus colegas. ","image":"https://hips.hearstapps.com/hmg-prod/images/psycho-pass-1584454230.jpg"},{"@type":"ListItem","position":28,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-28","name":"Pokémon","description":"En Pueblo Paleta, todos los niños y niñas están fascinados por el mundo de los Pokémon, unas criaturas de diferentes formas y colores que cuentan con unos poderes muy especiales. Ash Ketchum es uno de ellos, un niño de 10 años que sueña con llegar a ser el mejor entrenador Pokémon del mundo. ","image":"https://hips.hearstapps.com/hmg-prod/images/pokemon-1584454230.jpeg"},{"@type":"ListItem","position":29,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-29","name":"Cuando las cigarras lloran","description":"Higurashi no Naku Koro Ni narra la historia acerca de la llamada Maldición de Oyashiro-sama, consistente en el asesinato de una persona y la desaparición de otra, que se cumple todos los años en la tranquila villa de Hinamizawa desde unos incidentes de 5 años atrás durante la noche festiva del Watanagashi. Keiichi Maebara y su grupo de amigos, que hasta esa noche viven tranquilamente en la villa, se ven envueltos en el caso de la maldición en las varias sagas. Cada una de estas sagas revela varios detalles acerca de la \"maldición\" y tiene un final distinto que acaba, normalmente, con el asesinato de algunos miembros del grupo.","image":"https://hips.hearstapps.com/hmg-prod/images/cuando-las-cigarras-lloran-1584454227.jpg"},{"@type":"ListItem","position":30,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-30","name":"Doraemon","description":"Nobita y Doraemon se metan en miles de líos de los que deberán salir con una combinación de imaginación, suerte y valentía.","image":"https://hips.hearstapps.com/hmg-prod/images/doraemin-1584454720.jpg"},{"@type":"ListItem","position":31,"url":"https://www.fotogramas.es/series-tv-noticias/g31698003/series-anime-para-ver-netflix-amazon/#slide-31","name":"Bakugan Battle Planet","description":"Dan Kouzo y sus amigos son los primeros niños de la Tierra que crean un vínculo con unas misteriosas criaturas conocidas como Bakugan.","image":"https://hips.hearstapps.com/hmg-prod/images/bakugan-battle-planet-1584454720.jpg"}]}]</script><style data-emotion="css-global cfjyu2">.embed:has(> :nth-child(1)){clear:both;}@media (min-width: 90rem){.embed:not(.align-center):not([data-embed]="body-image"){clear:none;}}</style><style data-emotion="css-global 10dxqmb">#onetrust-banner-sdk{display:none;}</style><style data-emotion="css-global 7duge">body{--nav-height:105px;--sticky-header-height:105px;--sticky-navs-height:0px;}</style><style data-emotion="css-global 1hrpg85">html{line-height:1.15;-webkit-text-size-adjust:100%;}body{margin:0;}main{display:block;}h1{font-size:2em;margin:0.67em 0;}hr{box-sizing:content-box;height:0;overflow:visible;}pre{font-family:monospace,monospace;font-size:1em;}a{background-color:transparent;}abbr[title]{border-bottom:none;-webkit-text-decoration:underline;text-decoration:underline;-webkit-text-decoration:underline dotted;text-decoration:underline dotted;}b,strong{font-weight:bolder;}code,kbd,samp{font-family:monospace,monospace;font-size:1em;}small{font-size:80%;}sub,sup{font-siz